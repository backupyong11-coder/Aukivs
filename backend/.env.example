# 로컬: pip install -r requirements-dev.txt (pytest 포함) | 배포 빌드: requirements.txt 만
#
# Google Sheets — 체크리스트(/checklist)
# 로컬: 서비스 계정 JSON 파일 경로 (절대 경로 권장)
GOOGLE_SERVICE_ACCOUNT_FILE=C:\path\to\credentials.json
# Railway/Render 등: 파일 대신 JSON 본문을 변수로 (둘 중 하나만 쓰면 됨)
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# 줄바꿈 문제 시: GOOGLE_SERVICE_ACCOUNT_JSON_BASE64=<base64>  (이 변수가 있으면 JSON 문자열보다 우선)
# 스프레드시트 전체 URL (브라우저 주소창에서 복사)
GOOGLE_SHEET_URL=https://docs.google.com/spreadsheets/d/YOUR_SHEET_ID/edit
# 체크리스트 API(/checklist)가 읽는 탭 — 미설정 시 업무정리(=GOOGLE_TASKS_TAB)와 동일
# 비우면 GOOGLE_TASKS_TAB(기본: 업무정리)과 동일. 레거시 '체크리스트' 탭만 쓸 때만 지정.
# GOOGLE_CHECKLIST_TAB=체크리스트
# POST /checklist/complete 는 서비스 계정에 스프레드시트 편집자 권한이 필요합니다.
# 업로드 목록 탭 이름 (기본: 업로드운영) — 레거시 GET/POST /uploads* 전용 2행~ A:id B:title …
GOOGLE_UPLOADS_TAB=업로드운영
# 웹 '업로드정리' 화면(GET/POST /upload-rows*) — 기본: 업로드정리 (GOOGLE_UPLOADS_TAB 과 별도)
# GOOGLE_UPLOAD_ROWS_TAB=업로드정리

# 메모장 탭 (1행: 메모내용, 메모날짜, 메모분류)
GOOGLE_MEMO_TAB=메모장

# OpenAI — POST /ai/checklist/suggest, POST /ai/uploads/suggest (시트에 자동 저장하지 않음)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_TIMEOUT_SEC=45

# 배포 시: Vercel 프론트 도메인 (쉼표 구분, 로컬 localhost 는 기본 포함됨)
# BACKEND_CORS_ORIGINS=https://your-app.vercel.app
# 프리뷰 *.vercel.app 허용이 필요하면 (선택):
# BACKEND_CORS_ORIGIN_REGEX=https://.*\.vercel\.app

# GET /platform-master, GET /works-master — 시트 탭 이름(1행=헤더=JSON 키)
# GOOGLE_PLATFORM_TAB=플랫폼정리
# 작품정리 탭 열 예: A제작완료 B작품명 … M줄거리, N캐릭터 … X연재중인 사이트
# GOOGLE_WORKS_TAB=작품정리
