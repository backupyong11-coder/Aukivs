# --- 데모 외부 공개(선택) ---
# 값이 있으면 /demo-login 에서 PIN 입력 후에만 앱·/api/ops 접근 가능. 비우면 게이트 없음.
DEMO_PIN=1234

# --- API 연결(권장: 프록시만 사용) ---
# 비우면 브라우저·서버 모두 같은 출처의 /api/ops 로 FastAPI 호출 (외부 공개 시 이 방식 권장).
# NEXT_PUBLIC_API_BASE_URL=

# next dev / build 시 /api/ops → 아래 주소로 프록시
# 로컬: http://127.0.0.1:8001  |  Vercel: https://(Railway·Render 백엔드 URL) — 끝에 / 없이
OPSPROXY_TARGET=http://127.0.0.1:8001
